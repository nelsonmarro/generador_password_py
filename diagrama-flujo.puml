@startuml
!theme plain
skinparam roundcorner 0
skinparam activity {
  BackgroundColor lightblue
  BorderColor darkblue
  ArrowColor black
}

start

:Ingresar longitud (mínimo 8) y criterios; <<input>>

if (¿Longitud >= 8 y criterios > 0?) then (Sí)
  :Inicializar contraseña vacía y conjuntos;
  
  :Seleccionar un carácter de cada criterio activo;
  
  while (¿Faltan caracteres para alcanzar longitud?) is (Sí)
    :Seleccionar carácter aleatorio;
    :Añadir a la contraseña;
  endwhile (No)
  
  :Barajar los caracteres de la contraseña;
  
  :Mostrar contraseña generada; <<output>>
else (No)
  :Mostrar mensaje de error; <<output>>
endif

stop
@enduml
